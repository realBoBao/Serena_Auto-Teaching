# ═══════════════════════════════════════════════════════════
# DEPENDENCIES
# ═══════════════════════════════════════════════════════════
node_modules/

# ═══════════════════════════════════════════════════════════
# SECURITY — Never commit secrets
# ═══════════════════════════════════════════════════════════
.env
.env.local
.env.production
*.pem
*.key
vertex-key.json

# ═══════════════════════════════════════════════════════════
# DATABASES — Local data (large, user-specific)
# ═══════════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3
embedding_cache.db
bm25_index.db

# ═══════════════════════════════════════════════════════════
# DATA & BACKUPS — Generated artifacts
# ═══════════════════════════════════════════════════════════
artifacts/
backups/
*.csv
qdrant_storage/

# ═══════════════════════════════════════════════════════════
# MEDIA — Generated videos/images
# ═══════════════════════════════════════════════════════════
media/
*.mp4
*.png
*.jpg
*.jpeg

# ═══════════════════════════════════════════════════════════
# LARGE FILES — Use Git LFS or keep local only
# ═══════════════════════════════════════════════════════════
llama.cpp/
models/*.gguf
models/*.bin
models/*.safetensors

# ═══════════════════════════════════════════════════════════
# OS & EDITOR
# ═══════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ═══════════════════════════════════════════════════════════
# LOGS
# ═══════════════════════════════════════════════════════════
*.log
logs/
coverage/

# ═══════════════════════════════════════════════════════════
# TEMP FILES
# ═══════════════════════════════════════════════════════════
*.tmp
*.temp
debug_*.mjs
debug_*.js
check_*.mjs
check_*.js

# ═══════════════════════════════════════════════════════════
# RUNTIME DATA — Generated at runtime, not for git
# ═══════════════════════════════════════════════════════════
.query_dedup.json
.scheduler_last_run.json
